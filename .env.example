# ============================================================
# 自媒体口播脚本自动生成工厂 — 环境变量模板
# 复制此文件为 .env 并填入真实 API Key:
#   cp .env.example .env
# ============================================================

# --- DeepSeek API 配置 (兼容 OpenAI 格式) ---
# 注册地址: https://platform.deepseek.com/
# 模型列表: deepseek-chat, deepseek-reasoner
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- Tavily 搜索 API ---
# 注册地址: https://app.tavily.com/
# 用于 Agent 实时搜索热点话题和数据
TAVILY_API_KEY=tvly-your-tavily-key-here

# --- LangFuse 可观测 (层4启用，层1-3不用管) ---
# 注册地址: https://cloud.langfuse.com/
# 用于追踪 LLM 调用链路、成本和性能
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_SECRET_KEY=sk-lf-xxx
LANGFUSE_HOST=https://cloud.langfuse.com

# --- 日志级别 ---
# DEBUG=全量日志(含搜索细节/堆栈) INFO=关键流程(默认) WARNING=仅警告 ERROR=仅错误
LOG_LEVEL=INFO
